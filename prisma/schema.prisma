generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Province {
  id        String   @id @default(uuid())
  name      String   @unique
  headName  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isDeleted Boolean  @default(false)
  branches  Branch[]
  admins    User[]   @relation("ProvinceAdmin")
}

model Branch {
  id         String   @id @default(uuid())
  name       String
  city       String?
  provinceId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  headName   String?
  isDeleted  Boolean  @default(false)
  province   Province @relation(fields: [provinceId], references: [id])
  dojos      Dojo[]
  admins     User[]   @relation("BranchAdmin")
  events     Event[]

  @@unique([name, provinceId])
}

model Dojo {
  id                 String       @id @default(uuid())
  name               String
  address            String?
  contactPerson      String?
  branchId           String
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  kecamatan          String?
  phoneNumber        String?
  schedule           String?
  tempatLatihan      String?
  isDeleted          Boolean      @default(false)
  headName           String?
  latitude           Float?
  longitude          Float?
  geofenceRadius     Int          @default(50)
  bankName           String?
  bankAccountNumber  String?
  bankAccountName    String?
  attendances        Attendance[]
  branch             Branch       @relation(fields: [branchId], references: [id])
  members            Member[]
  admins             User[]       @relation("DojoAdmin")

  @@unique([name, branchId])
}

model User {
  id                String         @id @default(uuid())
  email             String         @unique
  passwordHash      String
  phoneNumber       String?
  isActive          Boolean        @default(true)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  isDeleted         Boolean        @default(false)
  fullName          String?
  managedBranchId   String?
  managedProvinceId String?
  managedDojoId     String?
  photoUrl          String?
  resetToken        String?        @unique
  resetTokenExpiry  DateTime?
  /// Waktu authorize/login sukses terakhir (Prisma lokal).
  lastLoginAt       DateTime?
  /// Waktu aktivitas terakhir (heartbeat); dipakai deteksi online + fallback tanpa Redis.
  lastSeenAt        DateTime?
  childrenMembers   Member[]       @relation("ParentChildren")
  member            Member?
  messages          Message[]
  notifications     Notification[]
  managedBranch     Branch?        @relation("BranchAdmin", fields: [managedBranchId], references: [id])
  managedProvince   Province?      @relation("ProvinceAdmin", fields: [managedProvinceId], references: [id])
  managedDojo       Dojo?          @relation("DojoAdmin", fields: [managedDojoId], references: [id])
  conversations     Conversation[] @relation("UserConversations")
  roles             Role[]         @relation("UserRoles")
  events            Event[]        @relation("UserEvents")
  auditLogs         AuditLog[]
  sessions          UserSession[]

  @@index([lastSeenAt])
  @@index([lastLoginAt])
}

/// Jejak sesi login untuk audit kehadiran (IP, perangkat, lokasi).
model UserSession {
  id           String    @id @default(uuid())
  userId       String
  startedAt    DateTime  @default(now())
  lastSeenAt   DateTime  @default(now())
  endedAt      DateTime?
  ip           String?
  userAgent    String?   @db.Text
  deviceType   String?
  browser      String?
  os           String?
  city         String?
  region       String?
  country      String?
  locationLabel String?
  timezone     String?
  language     String?
  screen       String?
  platform     String?
  isCurrent    Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isCurrent])
  @@index([userId, startedAt])
  @@index([lastSeenAt])
  @@index([ip])
}

model Role {
  id          String           @id @default(uuid())
  name        String           @unique
  permissions RolePermission[]
  users       User[]           @relation("UserRoles")
}

model Permission {
  id    String           @id @default(uuid())
  name  String           @unique
  slug  String           @unique
  roles RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id])
  role         Role       @relation(fields: [roleId], references: [id])

  @@id([roleId, permissionId])
}

model Member {
  id                    String              @id @default(uuid())
  userId                String?             @unique
  dojoId                String
  nia                   String?             @unique
  /// Nomor MSH — khusus sabuk Hitam (DAN)
  mshNumber             String?             @unique
  nik                   String?             @unique
  fullName              String
  gender                String?
  birthPlace            String?
  birthDate             DateTime?
  address               String?
  currentRank           String              @default("Putih (Kyu 10)")
  status                String              @default("Active")
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  isDeleted             Boolean             @default(false)
  allowEventWithoutDues Boolean             @default(false)
  monthlyDuesAmount     Float               @default(50000)
  parentUserId          String?
  birthCertificateUrl   String?
  bpjsCardUrl           String?
  bpjsCardNumber        String?
  bpjsOcrExtracted      Json?
  /// Anggota sudah 1x mengubah email akun sendiri → selanjutnya pengajuan
  emailSelfEditedAt     DateTime?
  /// Anggota sudah 1x mengubah NIA sendiri → selanjutnya pengajuan
  niaSelfEditedAt       DateTime?
  /// Anggota sudah 1x mengubah sabuk sendiri → selanjutnya pengajuan
  rankSelfEditedAt      DateTime?
  /// Anggota sudah 1x mengubah No. MSH sendiri → selanjutnya pengajuan
  mshSelfEditedAt       DateTime?
  attendances           Attendance[]
  billings              Billing[]
  eventRegistrations    EventRegistration[]
  dojo                  Dojo                @relation(fields: [dojoId], references: [id])
  parentUser            User?               @relation("ParentChildren", fields: [parentUserId], references: [id])
  user                  User?               @relation(fields: [userId], references: [id])
  ranks                 MemberRank[]
  verifications         Verification[]
  storeOrders           StoreOrder[]

  @@index([dojoId, status, isDeleted])
  @@index([fullName])
}

model MemberRank {
  id         String   @id @default(uuid())
  memberId   String
  rank       String
  date       DateTime
  location   String?
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())
  member     Member   @relation(fields: [memberId], references: [id])
}

model Attendance {
  id        String   @id @default(uuid())
  memberId  String
  dojoId    String
  eventId   String?
  checkInAt DateTime @default(now())
  method    String   @default("QR_SCAN")
  latitude  Float?
  longitude Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isDeleted Boolean  @default(false)
  dojo      Dojo     @relation(fields: [dojoId], references: [id])
  member    Member   @relation(fields: [memberId], references: [id])
  event     Event?   @relation(fields: [eventId], references: [id])

  @@index([memberId, eventId])
  @@index([checkInAt])
  @@index([dojoId, checkInAt])
}

model Billing {
  id             String   @id @default(uuid())
  memberId       String
  registrationId String?
  type           String
  amount         Float
  baseFeeAmount  Float?
  uniqueTail     Int?
  description    String?
  dueDate        DateTime
  status         String   @default("PENDING")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  isDeleted      Boolean  @default(false)
  member         Member   @relation(fields: [memberId], references: [id])
  payment        Payment?

  @@index([memberId, status, isDeleted])
  @@index([status, dueDate])
}

model Payment {
  id            String    @id @default(uuid())
  billingId     String    @unique
  paymentMethod String?
  externalId    String?   @unique
  proofUrl      String?
  paidAt        DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  billing       Billing   @relation(fields: [billingId], references: [id])
}

model Event {
  id                  String              @id @default(uuid())
  title               String
  description         String?
  startDate           DateTime
  endDate             DateTime
  registrationCloseAt DateTime?
  location            String?
  branchId            String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  isDeleted           Boolean             @default(false)
  createdById         String?
  createdBy           User?               @relation("UserEvents", fields: [createdById], references: [id])
  branch              Branch?             @relation(fields: [branchId], references: [id])
  categories          EventCategory[]
  registrations       EventRegistration[]
  verifications       Verification[]
  attendances         Attendance[]
}

model EventCategory {
  id            String              @id @default(uuid())
  eventId       String
  name          String
  fee           Float
  event         Event               @relation(fields: [eventId], references: [id])
  registrations EventRegistration[]
}

model EventRegistration {
  id                 String         @id @default(uuid())
  eventId            String
  memberId           String
  registeredByUserId String?
  categoryId         String?
  status             String         @default("PENDING")
  registeredRank     String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  category           EventCategory? @relation(fields: [categoryId], references: [id])
  event              Event          @relation(fields: [eventId], references: [id])
  member             Member         @relation(fields: [memberId], references: [id])

  @@unique([eventId, memberId])
}

model Product {
  id          String          @id @default(uuid())
  name        String
  description String?
  price       Float
  stock       Int             @default(0)
  imageUrl    String?
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  orderItems  StoreOrderItem[]
}

model DigitalMaterial {
  id          String   @id @default(uuid())
  title       String
  description String?
  fileUrl     String
  category    String?
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model StoreOrder {
  id        String           @id @default(uuid())
  memberId  String
  status    String           @default("PENDING")
  note      String?
  total     Float
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  member    Member           @relation(fields: [memberId], references: [id])
  items     StoreOrderItem[]
}

model StoreOrderItem {
  id        String     @id @default(uuid())
  orderId   String
  productId String
  quantity  Int
  unitPrice Float
  order     StoreOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product    @relation(fields: [productId], references: [id])
}

model Notification {
  id        String   @id @default(uuid())
  title     String
  content   String
  type      String   @default("INFO")
  // MEMBER | ADMIN | BROADCAST
  audience  String   @default("MEMBER")
  userId    String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([audience, createdAt])
}

model Verification {
  id         String   @id @default(uuid())
  memberId   String
  type       String
  data       String
  proofUrl   String
  status     String   @default("PENDING")
  adminNotes String?
  eventId    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  event      Event?   @relation(fields: [eventId], references: [id])
  member     Member   @relation(fields: [memberId], references: [id])

  @@index([status, createdAt])
  @@index([memberId, type])
}

model Conversation {
  id            String    @id @default(uuid())
  lastMessageAt DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now()) @updatedAt
  messages      Message[]
  participants  User[]    @relation("UserConversations")
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  senderId       String
  content        String
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  sender         User         @relation(fields: [senderId], references: [id])

  @@index([conversationId, isRead, senderId])
  @@index([isRead, senderId])
}

model AppSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NavTab {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  content   String   @db.Text
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NewsCarousel {
  id        String   @id @default(uuid())
  title     String
  imageUrl  String
  targetUrl String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RankFeeTemplate {
  id        String   @id @default(uuid())
  rankName  String   @unique
  fee       Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  email     String?
  action    String
  details   String?  @db.Text
  ip        String?
  userAgent String?  @db.Text
  location  String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}
