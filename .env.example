# inkai-backend API (wajib — semua CRUD lewat backend)
INKAI_API_URL="https://inkai-ecosystem.vercel.app"
NEXT_PUBLIC_INKAI_API_URL="https://inkai-ecosystem.vercel.app"

# Auth — NextAuth session membungkus JWT dari inkai-backend
AUTH_SECRET="ganti-dengan-secret-acak-minimal-32-karakter"
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Opsional: masih dipakai halaman UKT/admin SSR sampai modul UKT dipindah ke backend
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require"

# Optional: email reset password (Resend) — jika backend belum kirim email
# RESEND_API_KEY=
# EMAIL_FROM="INKAI Surabaya <noreply@yourdomain.com>"

# Optional: URL proyek Supabase (untuk storage gambar)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
