# inkai-backend API (wajib — semua CRUD lewat backend)
INKAI_API_URL="https://inkai-ecosystem.vercel.app"
NEXT_PUBLIC_INKAI_API_URL="https://inkai-ecosystem.vercel.app"

# Auth — NextAuth session membungkus JWT dari inkai-backend
AUTH_SECRET="ganti-dengan-secret-acak-minimal-32-karakter"
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Opsional: matikan mode ambil alih (impersonasi). Default aktif jika tidak diset.
# IMPERSONATION_ENABLED=false

# Opsional: masih dipakai halaman UKT/admin SSR sampai modul UKT dipindah ke backend
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require"

# Optional: email reset password (Resend) — jika backend belum kirim email
# RESEND_API_KEY=
# EMAIL_FROM="INKAI Surabaya <noreply@yourdomain.com>"

# Optional: URL proyek Supabase (untuk storage gambar)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"

# Optional: Vercel Blob — upload SK/foto pengurus di admin
# Buat token di Vercel Dashboard → Storage → Blob
BLOB_READ_WRITE_TOKEN=

# Optional: Upstash Redis — rate limit bersama antar instance serverless
# Tanpa ini, rate limit jatuh ke memori per instance (kurang efektif di Vercel)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Catatan pool DB: prefer Transaction pooler :6543 + ?pgbouncer=true&connection_limit=1
# Session mode (~15 client) sering memicu EMAXCONNSESSION di production
